# SEO Command Center configuration
# Copy to .env (or just run `python setup.py` — it writes this for you).
# NEVER commit .env.

# ── Required ────────────────────────────────────────────────────────────────
# DataForSEO API credentials — sign up at https://dataforseo.com (pay-as-you-go)
# Use the API login + API password from https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=you@example.com
DATAFORSEO_PASSWORD=your_api_password

# Password for the dashboard login page (hosted mode)
ACCESS_KEY=pick-something-strong
AUTH_SALT=any-random-string

# ── Branding ────────────────────────────────────────────────────────────────
# Defaults to the Tested Media logo (the folks who built this). Set your own:
# BRAND_NAME=Your Company
# Optional: path to your own SVG logo for the sidebar
# LOGO_FILE=~/my-logo.svg

# ── Hosted mode (optional, free) ────────────────────────────────────────────
# Puts the dashboard on Cloudflare Pages and unlocks the in-browser buttons:
# refresh, add keywords/sites, live keyword research, map-grid setup.
# Token needs: Cloudflare Pages: Edit + Workers KV Storage: Edit
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# CF_PAGES_PROJECT=seo-command-center
# CF_KV_NAMESPACE=   (created automatically by `python worker.py deploy-config`)

# ── Google Search Console (optional, free) ──────────────────────────────────
# Adds impressions/clicks and finds keywords Google already shows you for.
# See README → "Connect Search Console".
# GSC_CLIENT_SECRET=credentials/gsc-client-secret.json
# GSC_TOKENS=credentials/gsc-tokens.json

# ── Telegram alerts (optional) ──────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Tuning ──────────────────────────────────────────────────────────────────
# DAILY_REFRESH_HOUR=6
# Optional: dashboard URL appended to Telegram alerts
# DASHBOARD_URL=
